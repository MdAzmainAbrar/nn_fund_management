<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Allocation Form -->
    <record id="view_fund_allocation_form" model="ir.ui.view">
        <field name="name">nn.fund.allocation.form</field>
        <field name="model">nn.fund.allocation</field>
        <field name="arch" type="xml">
            <form string="Fund Allocation">
                <header>
                    <button name="action_submit" string="Submit" type="object"
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_gm_approve" string="GM Approve" type="object"
                            class="oe_highlight" invisible="state != 'gm_approval'"/>
                    <button name="action_md_approve" string="MD Approve" type="object"
                            class="oe_highlight" invisible="state != 'md_approval'"/>
                    <button name="action_reject" string="Reject" type="object"
                            invisible="state not in ('gm_approval', 'md_approval')"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state in ('approved', 'rejected', 'cancelled')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,gm_approval,md_approval,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="fund_account_id"/>
                            <field name="allocation_type"/>
                            <field name="project_id" invisible="allocation_type != 'project'"/>
                            <field name="expense_head_id" invisible="allocation_type != 'expense'"/>
                            <field name="amount"/>
                        </group>
                        <group>
                            <field name="purpose"/>
                            <field name="request_date"/>
                            <field name="requested_by"/>
                            <field name="attachment"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Approval History">
                            <field name="approval_history_ids" readonly="1">
                                <tree>
                                    <field name="date"/>
                                    <field name="approver_id"/>
                                    <field name="level"/>
                                    <field name="comment"/>
                                    <field name="result"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_fund_allocation_list" model="ir.ui.view">
        <field name="name">nn.fund.allocation.list</field>
        <field name="model">nn.fund.allocation</field>
        <field name="arch" type="xml">
            <tree string="Fund Allocations">
                <field name="name"/>
                <field name="fund_account_id"/>
                <field name="allocation_type"/>
                <field name="project_id"/>
                <field name="expense_head_id"/>
                <field name="amount"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="action_fund_allocation" model="ir.actions.act_window">
        <field name="name">Fund Allocations</field>
        <field name="res_model">nn.fund.allocation</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_fund_allocation"
        name="Fund Allocations"
        parent="menu_fund_management_root"
        action="action_fund_allocation"
        sequence="25"/>

</odoo>