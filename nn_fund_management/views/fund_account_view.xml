<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form View -->
    <record id="view_fund_account_form" model="ir.ui.view">
        <field name="name">nn.fund.account.form</field>
        <field name="model">nn.fund.account</field>
        <field name="arch" type="xml">
            <form string="Fund Account">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Account Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="account_type"/>
                            <field name="notes"/>
                        </group>
                        <group>
                            <field name="total_received"/>
                            <field name="unassigned_balance"/>
                            <field name="on_hold"/>
                            <field name="total_assigned"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_fund_account_list" model="ir.ui.view">
        <field name="name">nn.fund.account.list</field>
        <field name="model">nn.fund.account</field>
        <field name="arch" type="xml">
            <tree string="Fund Accounts">
                <field name="name"/>
                <field name="account_type"/>
                <field name="total_received"/>
                <field name="unassigned_balance"/>
                <field name="on_hold"/>
                <field name="total_assigned"/>
            </tree>
        </field>
    </record>

    <!-- Action -->
    <record id="action_fund_account" model="ir.actions.act_window">
    <field name="name">Fund Accounts</field>
    <field name="res_model">nn.fund.account</field>
    <field name="view_mode">tree,form</field>
    </record>
    <!-- Menu -->
    <menuitem id="menu_fund_management_root"
    name="Fund Management"
    sequence="10"/>

    <menuitem id="menu_fund_accounts"
    name="Fund Accounts"
    parent="menu_fund_management_root"
    action="action_fund_account"
    sequence="10"/>

</odoo>