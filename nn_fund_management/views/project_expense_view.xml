<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Project Form -->
    <record id="view_fund_project_form" model="ir.ui.view">
        <field name="name">nn.fund.project.form</field>
        <field name="model">nn.fund.project</field>
        <field name="arch" type="xml">
            <form string="Project">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Project Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="description"/>
                        </group>
                        <group>
                            <field name="total_allocated"/>
                            <field name="available_balance"/>
                            <field name="requisition_hold"/>
                            <field name="transfer_hold"/>
                            <field name="total_spent"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_fund_project_list" model="ir.ui.view">
        <field name="name">nn.fund.project.list</field>
        <field name="model">nn.fund.project</field>
        <field name="arch" type="xml">
            <tree string="Projects">
                <field name="name"/>
                <field name="code"/>
                <field name="total_allocated"/>
                <field name="available_balance"/>
                <field name="total_spent"/>
            </tree>
        </field>
    </record>

    <record id="action_fund_project" model="ir.actions.act_window">
        <field name="name">Projects</field>
        <field name="res_model">nn.fund.project</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Expense Head Form -->
    <record id="view_expense_head_form" model="ir.ui.view">
        <field name="name">nn.expense.head.form</field>
        <field name="model">nn.expense.head</field>
        <field name="arch" type="xml">
            <form string="Expense Head">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Expense Head Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="description"/>
                        </group>
                        <group>
                            <field name="total_allocated"/>
                            <field name="available_balance"/>
                            <field name="requisition_hold"/>
                            <field name="transfer_hold"/>
                            <field name="total_spent"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_expense_head_list" model="ir.ui.view">
        <field name="name">nn.expense.head.list</field>
        <field name="model">nn.expense.head</field>
        <field name="arch" type="xml">
            <tree string="Expense Heads">
                <field name="name"/>
                <field name="code"/>
                <field name="total_allocated"/>
                <field name="available_balance"/>
                <field name="total_spent"/>
            </tree>
        </field>
    </record>

    <record id="action_expense_head" model="ir.actions.act_window">
        <field name="name">Expense Heads</field>
        <field name="res_model">nn.expense.head</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Menus -->
    <menuitem id="menu_projects"
        name="Projects"
        parent="menu_fund_management_root"
        action="action_fund_project"
        sequence="30"/>

    <menuitem id="menu_expense_heads"
        name="Expense Heads"
        parent="menu_fund_management_root"
        action="action_expense_head"
        sequence="40"/>

</odoo>